# Database Configuration
DB_HOST=localhost
DB_NAME=srilive
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_TIMEZONE=+05:30

# Application Configuration
APP_NAME=WHMS - Warehouse Management System
APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=Asia/Kolkata
APP_URL=http://localhost/srihari-live

# Session Configuration
SESSION_LIFETIME=7200
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE=false
SESSION_HTTPONLY=true

# Google Maps API
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Delhivery API Configuration
DELHIVERY_API_BASE_URL=https://track.delhivery.com/api
DELHIVERY_API_KEY=
DELHIVERY_API_TOKEN=

# Shiprocket API Configuration
SHIPROCKET_API_BASE_URL=https://apiv2.shiprocket.in
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME=WHMS System

# WhatsApp Configuration
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# File Upload Configuration
UPLOAD_MAX_SIZE=50MB
UPLOAD_PATH=assets/uploads
IMAGE_COMPRESSION_QUALITY=80
IMAGE_MAX_SIZE_KB=50

# Security Configuration
JWT_SECRET=
ENCRYPTION_KEY=
HASH_ALGO=sha256

# Logging Configuration
LOG_PATH=logs
LOG_LEVEL=debug
LOG_MAX_FILES=30

# Cron Job Configuration
CRON_DELHIVERY_ENABLED=true
CRON_SHIPROCKET_ENABLED=true
CRON_EXECUTION_TIME=02:00

# API Rate Limiting
API_RATE_LIMIT=100
API_RATE_LIMIT_WINDOW=60

# Pagination
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=1000

# Currency and Number Formatting
DEFAULT_CURRENCY=INR
CURRENCY_SYMBOL=₹
DECIMAL_PLACES=2

# Date/Time Formats
DATE_FORMAT=Y-m-d
TIME_FORMAT=H:i:s
DATETIME_FORMAT=Y-m-d H:i:s

# System Settings
DEFAULT_ROLE_ID=1
ADMIN_USER_ID=1
ENABLE_CLIENT_ACCESS=true
ENABLE_MOBILE_APP=false

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_PATH=backups
BACKUP_SCHEDULE=daily
BACKUP_RETENTION_DAYS=30

# Cache Configuration
CACHE_DRIVER=file
CACHE_PREFIX=whms_
CACHE_TTL=3600

# Debug and Development
DEBUG_BAR=false
QUERY_LOG=true
ERROR_REPORTING=E_ALL
